# R session files
.Rhistory
.RData
.Rproj.user/
*.Rproj

# renv library (packages are restored from renv.lock)
renv/library/
renv/local/
renv/cellar/
renv/lock/
renv/python/
renv/staging/

# Pipeline outputs (regenerated by the pipeline)
output/

# Sensitive data and credentials
.env
credentials*
*.key

# Raw data (should not be committed — document access in data/README.md)
data/*.csv
data/*.xlsx
data/*.xls
data/*.ods
data/*.sav
data/*.dta

# OS files
.DS_Store
Thumbs.db

# Byte-compiled files
*.o
*.so
*.dll
