#   scale_colour_govuk() +
#   labs(
#     title = "Trend in [metric] over time",
#     subtitle = "United Kingdom, 2020 to 2025",
#     x = NULL,
#     y = "Count",
#     caption = "Source: [Department / Survey name]"
#   ) +
#   annotate_govuk("Peak in Q3 2023", x = 2023.5, y = 150)
